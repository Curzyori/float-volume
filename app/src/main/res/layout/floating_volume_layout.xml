<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_container"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:padding="8dp">

    <!-- Slider panel: slides out next to the bubble -->
    <LinearLayout
        android:id="@+id/slider_panel"
        android:layout_width="wrap_content"
        android:layout_height="44dp"
        android:layout_marginEnd="8dp"
        android:background="@drawable/slider_bg"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:visibility="gone">

        <ImageView
            android:id="@+id/slider_volume_icon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_volume_control_icon"
            android:contentDescription="Volume Indicator" />

        <SeekBar
            android:id="@+id/volume_seekbar"
            android:layout_width="120dp"
            android:layout_height="wrap_content"
            android:maxHeight="4dp"
            android:minHeight="4dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:thumbTint="#FFFFFF"
            android:progressTint="#FFFFFF"
            android:progressBackgroundTint="#55FFFFFF" />

        <TextView
            android:id="@+id/volume_percentage"
            android:layout_width="32dp"
            android:layout_height="wrap_content"
            android:text="50%"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:gravity="center"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <!-- The interactive volume bubble (white circle with high-contrast icon) -->
    <FrameLayout
        android:id="@+id/floating_button"
        android:layout_width="54dp"
        android:layout_height="54dp"
        android:background="@drawable/floating_circle_bg"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:id="@+id/floating_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_volume_control_icon"
            android:contentDescription="Toggle Volume Controls"
            android:visibility="gone" />
    </FrameLayout>
</LinearLayout>
